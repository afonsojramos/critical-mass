{
  "name": "critical-mass",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "paraglide-js compile --project ./project.inlang --outdir ./src/paraglide && astro check && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "vp lint .",
    "format": "vp fmt . --write",
    "machine-translate": "inlang machine translate --project project.inlang",
    "optimize": "optimizt --webp public/images",
    "svg": "svgo -r -f",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/cloudflare": "^13.6.1",
    "@astrojs/react": "^5.0.7",
    "@astrojs/sitemap": "^3.7.3",
    "@emdash-cms/auth-atproto": "^0.2.23",
    "@emdash-cms/cloudflare": "^0.16.1",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-router": "^1.170.16",
    "astro": "^6.4.3",
    "astro-navbar": "^2.4.0",
    "astro-portabletext": "^0.13.0",
    "emdash": "^1.0.0",
    "husky": "^9.1.7",
    "lenis": "^1.3.25",
    "node-html-parser": "^8.0.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sharp": "^0.35.3",
    "swiper": "^14.0.1",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@funboxteam/optimizt": "^5.0.2",
    "@inlang/cli": "^3.1.14",
    "@inlang/paraglide-js": "^2.20.2",
    "@tailwindcss/typography": "^0.5.20",
    "gray-matter": "^4.0.3",
    "jsdom": "^29.1.1",
    "rehype-stringify": "^10.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unified": "^11.0.5"
  },
  "trustedDependencies": [
    "@tailwindcss/oxide",
    "esbuild",
    "sharp",
    "workerd"
  ]
}
