---
import Footer from "@/components/ui/Footer.astro";
import Navbar from "@/components/ui/Navbar.astro";
import MainHead from "./MainHead.astro";
import "@/styles/global.css";

// `localeSwitchHref` (optional) is the precomputed other-locale URL for the
// language switcher on content/term pages; the rest are head/meta props.
const { localeSwitchHref, ...headProps } = Astro.props;
---

<html lang={Astro.currentLocale}>
  <MainHead {...headProps} />
  <style>
    html.lenis {
      height: auto;
    }
    .lenis.lenis-smooth {
      scroll-behavior: auto;
    }
    .lenis.lenis-smooth [data-lenis-prevent] {
      overscroll-behavior: contain;
    }
    .lenis.lenis-stopped {
      overflow: hidden;
    }
  </style>
  <script src="../utils/lenis"></script>
  <body class="bg-white font-grotesk">
    <Navbar localeSwitchHref={localeSwitchHref} />
    <main class="flex flex-col min-h-screen lg:mt-20">
      <slot />
      <Footer />
    </main>
    <script>
      import { BlockRate } from "blockrate";

      // Measures which analytics providers ad blockers block for visitors and
      // reports to the same-origin /api/block-rate route (which forwards
      // server-side to blockrate.app). Consent-free: no cookies, no storage,
      // no identifiers. See https://blockrate.app.
      new BlockRate({
        providers: [
          "amplitude",
          "ga4",
          "gtm",
          "hotjar",
          "intercom",
          "meta-pixel",
          "mixpanel",
          "optimizely",
          "posthog",
          "segment",
        ],
        service: "massacritica.pt",
        reporter: (result) => {
          navigator.sendBeacon("/api/block-rate", JSON.stringify(result));
        },
      }).check();
    </script>
  </body>
</html>
