---
export const prerender = false;

import { getEmDashCollection } from "emdash";
import ArticleCard from "@/components/ui/ArticleCard.astro";
import MainLayout from "@/layouts/MainLayout.astro";
import { createTagSlug, translateTag } from "@/lib/tagMapper";
import * as m from "@/paraglide/messages";
import { capitalize } from "@/utils";

const { tag } = Astro.params;
const locale = Astro.currentLocale as "pt" | "en";

if (!tag) {
  return Astro.redirect(`/${locale}/articles`);
}

const { entries } = await getEmDashCollection("blog", {
  status: "published",
  locale,
  where: { tags: tag },
  orderBy: { pub_date: "desc" },
});
// biome-ignore lint/suspicious/noExplicitAny: Emdash returns untyped data
const tagArticles = entries as any[];

// Get the actual English tag for translation (find first match)
const actualTag =
  tagArticles
    // biome-ignore lint/suspicious/noExplicitAny: Emdash returns untyped data
    .flatMap((article: any) => article.data.tags)
    .find((articleTag: string) => createTagSlug(articleTag) === tag) || tag;

// Translate tag for display
const displayTag = translateTag(actualTag, locale);

Astro.response.headers.set("Cache-Control", "public, s-maxage=300, stale-while-revalidate=3600");
---

<MainLayout title={m.articles_tag()}>
  <main class="space-y-20 flex-grow">
    <div class="py-8 px-4 mx-auto max-w-screen-xl lg:py-16 lg:px-3">
      <a
        href={`/${locale}/articles`}
        class="inline-flex items-center font-medium text-black hover:text-green my-4"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          class="h-6 w-6"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M7 16l-4-4m0 0l4-4m-4 4h18"
          >
          </path>
        </svg>
        <span class="ml-1 font-bold text-lg">All Articles</span>
      </a>

      <h2 class="text-2xl pb-3">#{capitalize(displayTag)}</h2>
      <div class="grid gap-8 lg:grid-cols-2">
        {tagArticles.map((article) => <ArticleCard article={article} />)}
      </div>
    </div>
  </main>
</MainLayout>
