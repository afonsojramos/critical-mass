---
export const prerender = false;

import { PortableText } from "astro-portabletext";
import { getEmDashEntry } from "emdash";
import ContentImage from "@/components/ui/ContentImage.astro";
import Tags from "@/components/ui/Tags.astro";
import MainLayout from "@/layouts/MainLayout.astro";
import * as m from "@/paraglide/messages";
import { formatDate } from "@/utils";
import { editable } from "@/utils/editable";
import { entryLocaleSwitchHref } from "@/utils/localeSwitch";

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect(`/${Astro.currentLocale}/articles`);
}

const locale = Astro.currentLocale;
const { entry } = await getEmDashEntry("blog", slug, { locale });

if (!entry) {
  return new Response(null, { status: 404, statusText: "Not Found" });
}

// biome-ignore lint/suspicious/noExplicitAny: Emdash returns untyped data
const article = entry as any;
const { entry: authorEntry } = await getEmDashEntry("authors", article.data.author);
// biome-ignore lint/suspicious/noExplicitAny: Emdash returns untyped data
const author = authorEntry as any;

const edit = editable("blog", article);
const authorEdit = author ? editable("authors", author) : null;

// Language switch lands on this article's translation (slugs differ per locale).
const localeSwitchHref = await entryLocaleSwitchHref("blog", article.data.id, locale as string, "articles");

Astro.response.headers.set("Cache-Control", "public, s-maxage=300, stale-while-revalidate=3600");
---

<MainLayout
  title={article.data.title}
  description={article.data.summary}
  localeSwitchHref={localeSwitchHref}
>
  <main class="space-y-20">
    <section class="px-8 mx-auto max-w-4xl bg-white">
      <div
        class="gap-16 items-center py-8 px-4 mx-auto max-w-screen-xl lg:grid lg:grid-cols-1 lg:py-16 lg:px-3"
      >
        <div class="font-light text-gray-500 sm:text-lg">
          <a
            href={`/${Astro.currentLocale}/articles`}
            class="inline-flex items-center font-medium text-black hover:text-green my-4"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              class="h-6 w-6"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M7 16l-4-4m0 0l4-4m-4 4h18"
              >
              </path>
            </svg>
            <span class="ml-1 font-bold text-lg">{m.blog_allArticles()}</span>
          </a>
          <h2 class="mb-4 text-4xl tracking-tight font-extrabold text-gray-900" {...edit.title}>
            {article.data.title}
          </h2>
          <div class="flex items-center space-x-3 mb-4">
            <ContentImage
              class="w-10 h-10 rounded-full"
              value={author?.data.image}
              alt={author?.data.name + " avatar"}
              width={40}
              height={40}
              {...(authorEdit?.image ?? {})}
            />
            <div>
              <h3 class="text-lg">
                {m.blog_writtenBy()}
                <span {...(authorEdit?.name ?? {})}>{author?.data.name}</span>
                {m.blog_on()}
                {formatDate(article.data.pub_date, Astro.currentLocale)}
              </h3>
            </div>
          </div>
          <Tags terms={article.data.terms?.tag ?? []} />
          <ContentImage
            value={article.data.image}
            alt="Article Image"
            class="w-full h-auto rounded-xl my-6"
            width={300}
            height={200}
            loading="eager"
            {...edit.image}
          />
          <div class="prose prose-lg max-w-none" {...edit.body}>
            <PortableText value={article.data.body} />
          </div>
        </div>
      </div>
    </section>
  </main>
</MainLayout>
