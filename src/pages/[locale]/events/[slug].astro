---
export const prerender = false;

import { PortableText } from "astro-portabletext";
import { getEmDashEntry } from "emdash";
import EventCarousel from "@/components/ui/EventCarousel.astro";
import MainLayout from "@/layouts/MainLayout.astro";
import * as m from "@/paraglide/messages";
import { editable } from "@/utils/editable";

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect(`/${Astro.currentLocale}/events`);
}

const locale = Astro.currentLocale;
const { entry } = await getEmDashEntry("events", slug, { locale });

if (!entry) {
  return new Response(null, { status: 404, statusText: "Not Found" });
}

// biome-ignore lint/suspicious/noExplicitAny: Emdash returns untyped data
const event = entry as any;

const edit = editable("events", event);

Astro.response.headers.set("Cache-Control", "public, s-maxage=300, stale-while-revalidate=3600");
---

<MainLayout title={event.data.title} description={event.data.description}>
  <article class="py-12 bg-white">
    <div class="px-8 mx-auto max-w-4xl">
      <a
        href={`/${Astro.currentLocale}/events`}
        class="inline-flex items-center font-medium text-black hover:text-green my-4"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          class="h-6 w-6"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M7 16l-4-4m0 0l4-4m-4 4h18"
          >
          </path>
        </svg>
        <span class="ml-1 font-bold text-lg">{m.events_viewAll()}</span>
      </a>

      <header class="mb-8" {...edit}>
        <h1 class="text-4xl md:text-5xl font-bold mb-4" {...edit.title}>{event.data.title}</h1>
        <div class="bg-gray-100 p-5 rounded-lg mb-8">
          <p class="text-xl" {...edit.description}>{event.data.description}</p>
        </div>
      </header>
      <div class="relative h-80 md:h-96 w-full mb-8 rounded-xl overflow-hidden" {...edit.images}>
        {
          event.data.images && event.data.images.length > 0 ? (
            <EventCarousel
              images={event.data.images}
              eventTitle={event.data.title}
            />
          ) : (
            <div class="h-full w-full bg-gray-200 flex items-center justify-center">
              <span class="text-gray-400 text-xl">{m.events_noImage()}</span>
            </div>
          )
        }
      </div>
      <!-- Event content -->
      <div class="prose prose-lg max-w-none" {...edit.body}>
        <PortableText value={event.data.body} />
      </div>
    </div>
  </article>
</MainLayout>
