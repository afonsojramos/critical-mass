---
export const prerender = false;

import { getTaxonomyTerms } from "emdash";
import GalleryView from "@/components/sections/GalleryView.astro";
import MainLayout from "@/layouts/MainLayout.astro";
import * as m from "@/paraglide/messages";

const { category } = Astro.params;
const locale = Astro.currentLocale as "pt" | "en";

// Page title from the category taxonomy term label (falls back to the slug).
const terms = await getTaxonomyTerms("category", { locale });
// biome-ignore lint/suspicious/noExplicitAny: Emdash returns untyped data
const categoryLabel = (terms as any[]).find((t) => t.slug === category)?.label ?? category;
const categoryTitle = `${m.gallery_title()} - ${categoryLabel}`;

Astro.response.headers.set("Cache-Control", "public, s-maxage=300, stale-while-revalidate=3600");
---

<MainLayout title={categoryTitle} description={m.gallery_description()}>
  <GalleryView filterCategory={category} />
</MainLayout>
