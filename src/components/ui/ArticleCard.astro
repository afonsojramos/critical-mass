---
import { getEmDashEntry } from "emdash";
import ArticleIcon from "@/components/Icons/ArticleIcon.astro";
import VideoIcon from "@/components/Icons/VideoIcon.astro";
import Card from "@/components/ui/Card.astro";
import ContentImage from "@/components/ui/ContentImage.astro";
import { formatDate } from "@/utils";
import { editable } from "@/utils/editable";

const lang = Astro.currentLocale;

const { article } = Astro.props;

interface Props {
  // biome-ignore lint/suspicious/noExplicitAny: Emdash returns untyped data
  article: any;
}

const { entry: authorEntry } = await getEmDashEntry("authors", article.data.author);
// biome-ignore lint/suspicious/noExplicitAny: Emdash returns untyped data
const author = authorEntry as any;

const edit = editable("blog", article);
const authorEdit = author ? editable("authors", author) : null;
---

<Card isUnderline={true}>
  <article class="p-6" {...edit}>
    <div class="flex justify-between items-center mb-5 text-gray-500">
      <span
        class="bg-green text-black text-xs font-medium inline-flex items-center px-2.5 py-0.5 rounded"
        {...edit.content_type}
      >
        {article.data.content_type == "Article" ? <ArticleIcon /> : <VideoIcon />}
        {article.data.content_type}
      </span>
      <span class="text-sm" {...edit.pub_date}>{formatDate(article.data.pub_date)}</span>
    </div>
    <h2 class="mb-2 text-2xl font-bold tracking-tight text-gray-900" {...edit.title}>
      {article.data.title}
    </h2>
    <p class="mb-5 font-light text-gray-500" style="white-space: pre-line" {...edit.summary}>
      {article.data.summary}
    </p>
    <div class="flex justify-between items-center">
      <div class="flex items-center space-x-4">
        <ContentImage
          class="w-7 h-7 rounded-full"
          value={author?.data.image}
          alt={author?.data.name + " avatar"}
          height={28}
          width={28}
          {...(authorEdit?.image ?? {})}
        />
        <span class="font-medium">
          {author?.data.social_media_link ? (
            <a
              href={author.data.social_media_link}
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-green underline decoration-dotted underline-offset-2"
              {...(authorEdit?.name ?? {})}
            >
              {author.data.name}
            </a>
          ) : (
            <span {...(authorEdit?.name ?? {})}>{author?.data.name}</span>
          )}
        </span>
      </div>
      <a
        href={`/${lang}/articles/${article.id}`}
        class="inline-flex items-center font-medium text-black hover:text-green"
      >
        Read more
        <svg
          class="ml-2 w-4 h-4"
          fill="currentColor"
          viewBox="0 0 20 20"
          xmlns="http://www.w3.org/2000/svg"
          ><path
            fill-rule="evenodd"
            d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z"
            clip-rule="evenodd"></path></svg
        >
      </a>
    </div>
  </article>
</Card>
