---
import { Image } from "astro:assets";
import BragaCiclavel from "@/assets/communities/braga-ciclavel.png";
import ciclaveiro from "@/assets/communities/ciclaveiro.svg?raw";
import Cicloda from "@/assets/communities/cicloda.png";
import CicloficinaPorto from "@/assets/communities/cicloficina-porto.png";
import EstradaViva from "@/assets/communities/estrada-viva.png";
import FPC from "@/assets/communities/FPC.png";
import FPCUB from "@/assets/communities/FPCUB.jpg";
import kidicalMass from "@/assets/communities/kidical-mass.svg?raw";
import Mubi from "@/assets/communities/mubi-cropped.png";
import logo from "@/assets/logo-alt.svg?raw";
import * as m from "@/paraglide/messages";

const contacts = {
  name: "afonso jorge ramos",
  email: "contributions@massacritica.pt",
  href: "https://afonsojramos.me",
  github: "https://github.com/afonsojramos/critical-mass",
};
---

<section class="sm:px-5 w-full max-w-[1280px] mx-auto">
  <div
    class="flex flex-col items-center justify-around bg-dark text-gray py-[55px] px-4 lg:px-0 sm:rounded-t-[45px] gap-8"
  >
    <a href="#home" class="flex items-center">
      <div class="size-24 text-white [&>svg]:size-full">
        <Fragment set:html={logo} />
      </div>
      <h2 class="text-white text-2xl font-bold uppercase">
        {
          m
            .hero_title()
            .split("\n")
            .map((line, index) => (
              <span class={`block ${index > 0 && "text-4xl"}`}>{line}</span>
            ))
        }
      </h2>
    </a>
    <div class="flex flex-col lg:flex-row gap-16 items-center">
      <div class="flex flex-col gap-8 items-center">
        <h3 class="text-green text-center text-2xl lg:text-start">
          {m.communities()}
        </h3>
        <div
          class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 max-w-lg"
        >
          <a href="https://mubi.pt" class="h-12 w-auto" title="Mubi">
            <Image
              src={Mubi}
              alt="Logo for Mubi"
              class="text-white h-full w-full object-contain"
              loading="lazy"
            />
          </a>
          <a
            href="https://kidicalmass.pt"
            class="h-12 w-auto"
            title="Kidical Mass"
          >
            <div class="text-white h-full w-full [&>svg]:h-full [&>svg]:w-full">
              <Fragment set:html={kidicalMass} />
            </div>
          </a>
          <a href="https://fpciclaveiro.pt" class="h-12 w-auto bg-white rounded-lg p-1" title="FPC">
            <Image
              src={FPC}
              alt="Logo for FPC"
              class="h-full w-full object-contain"
              loading="lazy"
            />
          </a>
          <a
            href="https://cicloficina.cicloda.pt"
            class="h-12 w-auto bg-white rounded-lg p-1"
            title="Cicloficina Porto"
          >
            <Image
              src={CicloficinaPorto}
              alt="Logo for Cicloficina Porto"
              class="h-full w-full object-contain"
              loading="lazy"
            />
          </a>
          <a href="https://fpcub.pt" class="h-12 w-auto bg-white rounded-lg p-1" title="FPCUB">
            <Image
              src={FPCUB}
              alt="Logo for FPCUB"
              class="h-full w-full object-contain"
              loading="lazy"
            />
          </a>
          <a
            href="https://bragaciclavel.pt"
            class="h-12 w-auto bg-white rounded-lg p-1"
            title="Braga Ciclável"
          >
            <Image
              src={BragaCiclavel}
              alt="Logo for Braga Ciclável"
              class="h-full w-full object-contain"
              loading="lazy"
            />
          </a>
          <a
            href="https://ciclaveiro.pt"
            class="h-12 w-auto bg-white rounded-lg p-1"
            title="Ciclaveiro"
          >
            <div class="h-full w-full [&>svg]:h-full [&>svg]:w-full">
              <Fragment set:html={ciclaveiro} />
            </div>
          </a>
          <a
            href="https://estradaviva.pt"
            class="h-12 w-auto bg-white rounded-lg p-1"
            title="Estrada Viva"
          >
            <Image
              src={EstradaViva}
              alt="Logo for Estrada Viva"
              class="h-full w-full object-contain"
              loading="lazy"
            />
          </a>
          <a href="https://cicloda.pt" class="h-12 w-auto" title="Cicloda">
            <Image
              src={Cicloda}
              alt="Logo for Cicloda"
              class="h-full w-full object-contain"
              loading="lazy"
            />
          </a>
        </div>
      </div>
      <div
        class="flex text-center lg:text-start items-center lg:items-start flex-col self-center"
      >
        <h3 class="mb-5 text-center lg:text-left text-2xl text-green">
          {m.footer_contribute}
        </h3>
        <p class="text-center lg:text-left">
          {m.footer_contact}
        </p>
        <a
          href={`mailto:${contacts.email}`}
          target="_blank"
          class="hover:underline"
        >
          {contacts.email.split("@").join(" @ ")}
        </a>
      </div>
    </div>
    <div class="border-t border-gray-700 pt-6 mt-6 text-center">
      <p class="text-sm text-gray-400">
        Crafted with 💚 by <a href={contacts.href} target="_blank" class="text-green hover:text-white transition-colors">{contacts.name}</a>
      </p>
      <p class="text-xs text-gray-500 mt-2">
        <a href={contacts.github} target="_blank" class="text-gray-500 hover:text-green transition-colors">Source available on GitHub</a>
      </p>
    </div>
  </div>
</section>
