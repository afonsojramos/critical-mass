---
import { getRouteFromUrl } from "@/i18n/utils";
import { baseLocale, locales } from "@/paraglide/runtime";

interface Props {
  // Precomputed other-locale URL (used on content/term pages where the slug
  // differs per locale). When omitted, we swap the locale prefix in place.
  href?: string;
}

const { href } = Astro.props;
const currentLang = Astro.currentLocale;
const otherLang = locales.find((lang) => lang !== currentLang) || baseLocale;
const langLabels = {
  en: "English",
  pt: "Português",
};

const route = getRouteFromUrl(Astro.url);
const targetUrl = href ?? (route ? `/${otherLang}/${route}` : `/${otherLang}`);
---

<a href={targetUrl} class="hover:underline">
  {langLabels[otherLang]}
</a>
