---
import { getEmDashCollection, getEntriesByTerm, getTaxonomyTerms } from "emdash";
import GalleryCard from "@/components/ui/GalleryCard.astro";
import ImageModal from "@/components/ui/ImageModal.astro";
import * as m from "@/paraglide/messages";
import { capitalize } from "@/utils";
import { resolveBaseTermSlug } from "@/utils/taxonomy";

interface Props {
  filterCategory?: string;
}

const { filterCategory = "all" } = Astro.props;
const locale = Astro.currentLocale as "pt" | "en";

// Filter by the `category` taxonomy term (DB JOIN) when a category is set;
// otherwise list every published item. The URL slug is localized, so resolve
// it to the base-locale slug the term filter matches.
const entries =
  filterCategory === "all"
    ? (await getEmDashCollection("gallery", { status: "published", locale })).entries
    : await getEntriesByTerm(
        "gallery",
        "category",
        await resolveBaseTermSlug("category", filterCategory, locale),
        { locale },
      );

const sortedGalleryItems = (entries as any[]).sort((a, b) => {
  if (a.data.date && b.data.date) {
    return new Date(b.data.date as string).getTime() - new Date(a.data.date as string).getTime();
  }
  return (a.data.title as string).localeCompare(b.data.title as string);
});

// Filter buttons come from the taxonomy terms (managed in the CMS).
const categoryTerms = await getTaxonomyTerms("category", { locale });
---

<main class="space-y-20">
  <div class="py-8 px-4 mx-auto max-w-screen-xl lg:py-16 lg:px-3">
    <div class="text-center mb-4">
      <h1 class="text-5xl font-bold mb-4">{m.gallery_title()}</h1>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto">
        {m.gallery_description()}
      </p>
    </div>

    {categoryTerms.length > 0 && (
      <div class="flex flex-wrap justify-center gap-3 mb-8">
        <a
          href={`/${locale}/gallery/`}
          class={`px-4 py-2 rounded-full border-2 transition-colors ${
            filterCategory === "all"
              ? "bg-black text-white border-black"
              : "border-gray-300 hover:border-gray-400"
          }`}
        >
          All
        </a>
        {categoryTerms.map((term) => {
          const isActive = filterCategory === term.slug;
          return (
            <a
              href={`/${locale}/gallery/${term.slug}/`}
              class={`px-4 py-2 rounded-full border-2 transition-colors capitalize ${
                isActive
                  ? "bg-black text-white border-black"
                  : "border-gray-300 hover:border-gray-400"
              }`}
            >
              {capitalize(term.label)}
            </a>
          );
        })}
      </div>
    )}

    <div class="columns-1 md:columns-2 lg:columns-3 xl:columns-4 gap-6 space-y-6" id="gallery-grid">
      {
        sortedGalleryItems.map((galleryItem) => (
          <div class="break-inside-avoid mb-6">
            <GalleryCard galleryItem={galleryItem} />
          </div>
        ))
      }
    </div>

    {sortedGalleryItems.length === 0 && (
      <div class="text-center py-12">
        <p class="text-gray-500 text-lg">{m.gallery_noImages()}</p>
      </div>
    )}
  </div>
</main>
<ImageModal id="gallery-modal" />

<script>
  // Make global function for tag clicks - navigate to filtered page
  window.filterByTag = (tag: string) => {
    const currentLocale = document.documentElement.lang || 'pt';
    if (tag === 'all') {
      window.location.href = `/${currentLocale}/gallery/`;
    } else {
      window.location.href = `/${currentLocale}/gallery/${encodeURIComponent(tag)}/`;
    }
  };
</script>
