---
import { getEmDashCollection } from "emdash";
import Section from "@/components/sections/Section.astro";
import EventCard from "@/components/ui/EventCard.astro";
import SectionTitle from "@/components/ui/SectionTitle.astro";
import * as m from "@/paraglide/messages";

const lang = Astro.currentLocale || "pt";

// Filter for featured client-side since boolean where filters need a string match
// in Emdash but the field is stored as integer (0/1)
const { entries: allEvents } = await getEmDashCollection("events", {
  status: "published",
  locale: lang,
});
const featuredEvents = (allEvents as Array<{ id: string; data: Record<string, unknown> }>).filter(
  (e) => {
    const featured = e.data.featured;
    return featured === true || featured === 1 || featured === "true";
  },
);
---

<Section id="events">
  <div class="mt-24 mb-5">
    <SectionTitle
      sectionTitle={m.events_title}
      description={m.events_description}
    />

    <div class="grid lg:grid-cols-2 gap-10">
      {
        featuredEvents.map((event, index) => (
          <EventCard event={event} index={index} />
        ))
      }
    </div>

    <div class="mt-12 text-center">
      <a href={`/${lang}/events`} class="btn-secondary inline-block">
        {m.events_viewAll}
      </a>
    </div>
  </div>
</Section>
